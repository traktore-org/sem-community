{
  "config": {
    "step": {
      "user": {
        "title": "Solar Energy Management Setup",
        "description": "SEM has detected the following sensors from your Home Assistant Energy Dashboard:\n\n{summary}\n\nClick **Submit** to continue. The next two steps auto-detect your EV charger and inverter — almost everything is filled in for you.",
        "data": {
          "observer_mode": "Test mode (read-only — do not control hardware)"
        },
        "data_description": {
          "observer_mode": "Leave OFF for a normal install. Turn ON only on a test/staging Home Assistant that mirrors a production instance, so SEM never sends commands to KEBA, the inverter, or any switches."
        }
      },
      "ev_charger": {
        "title": "EV Charger",
        "description": "SEM auto-detected your EV charger from the Home Assistant entity registry. Review the entries below and click **Submit** — there is usually nothing to change. Optional fields can be left blank.",
        "data": {
          "ev_connected_sensor": "🔌 EV Connected Status — vehicle plug connection",
          "ev_charging_sensor": "⚡ EV Charging Active — current charging state",
          "ev_charging_power_sensor": "🚗 EV Charging Power — power delivered to vehicle (W)",
          "ev_charger_service": "EV Charger Set-Current Service (optional)",
          "ev_charger_service_entity_id": "EV Charger Service Target Entity (optional)",
          "ev_current_sensor": "⚡ EV Charging Current — charging amperage (A)",
          "ev_total_energy_sensor": "🔋 EV Total Energy — cumulative energy delivered (kWh)"
        },
        "data_description": {
          "ev_connected_sensor": "Binary sensor that reports whether the vehicle plug is currently connected. Auto-detected from KEBA / Easee / Wallbox / go-eCharger.",
          "ev_charging_sensor": "Binary sensor that reports whether SEM should consider charging active. Auto-detected from your charger integration.",
          "ev_charging_power_sensor": "Numeric sensor (W) reporting how much power is currently flowing into the vehicle. Auto-detected from your charger integration.",
          "ev_charger_service": "Home Assistant service called to set the charging current (e.g. keba.set_current, easee.set_charger_max_limit). Auto-filled for KEBA. Leave blank for chargers controlled via a number entity.",
          "ev_charger_service_entity_id": "Entity ID passed as the target of the service call. Auto-filled when needed; leave blank if the service is global.",
          "ev_current_sensor": "Optional. Numeric sensor (A) reporting the actual charging current. Used for diagnostics.",
          "ev_total_energy_sensor": "Optional. Cumulative kWh counter for energy delivered to the vehicle. Used for accurate session tracking."
        }
      },
      "hardware": {
        "title": "Hardware",
        "description": "Two final values that depend on your installation:\n\n• Home Battery Capacity — the usable kWh of your inverter battery.\n• Peak Power Limit — the maximum kW your grid contract allows before SEM starts shedding load.\n\nSEM also auto-detected your inverter's discharge control entity: {discharge_entity}\n\nLeave the dashboard option ON to have SEM build its Lovelace dashboard for you. **Note: this triggers a Home Assistant restart about 5 seconds after install completes.**\n\nEverything else uses safe defaults that you can tune later from the integration's options.",
        "data": {
          "battery_capacity_kwh": "Home Battery Capacity (kWh)",
          "target_peak_limit": "Peak Power Limit (kW)",
          "generate_dashboard_on_install": "Generate the SEM dashboard now (restarts HA)"
        },
        "data_description": {
          "battery_capacity_kwh": "Total usable capacity of your home battery (NOT the EV) in kWh. Used by the forecast-driven charging strategy to estimate how much battery can bridge a solar deficit. Check your inverter spec.",
          "target_peak_limit": "Maximum kW your grid contract allows before SEM begins load-shedding. For demand-based tariffs typically 3–5 kW; otherwise set to your fuse rating divided by 4 to leave headroom.",
          "generate_dashboard_on_install": "When enabled, SEM creates the Lovelace dashboard immediately after this step finishes and then restarts Home Assistant ~5 s later so the new dashboard becomes visible. You can always re-run it manually later via the solar_energy_management.generate_dashboard service."
        }
      },
      "reconfigure": {
        "title": "Reconfigure Solar Energy Management",
        "description": "Update your EV charger and notification settings",
        "data": {
          "ev_connected_sensor": "EV Connected Status",
